# ============================================================
# FILE MẪU CẤU HÌNH - SAO CHÉP THÀNH .env VÀ ĐIỀN KEY THẬT
# Hướng dẫn: cp .env.example .env  rồi mở file .env và điền thông tin
# ============================================================

# --- Thông tin Supabase (lấy từ Project Settings > API) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# --- Thông tin UUID người dùng và chuyến đi ---
USER_ID=00000000-0000-0000-0000-000000000000
TRIP_ID=11111111-1111-1111-1111-111111111111
