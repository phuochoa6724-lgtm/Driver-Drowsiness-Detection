# --- Thông tin cấu hình Supabase ---
# SUPABASE_URL: URL dự án Supabase của bạn (ví dụ: https://xyz.supabase.co)
SUPABASE_URL=your_supabase_url_here

# SUPABASE_KEY: Khóa API (Service Role hoặc Anon Key)
SUPABASE_KEY=your_supabase_key_here

# USER_ID: Mã định danh người dùng (mặc định: local_user)
USER_ID=local_user

# --- Thông tin cấu hình Camera ---
# CAMERA_SOURCE: Nguồn video đầu vào.
# - Đặt = 0 nếu muốn sử dụng camera mặc định trên máy (webcam).
# - Nếu dùng app IP Camera từ điện thoại, đặt URL vào đây, ví dụ: http://192.168.1.5:8080/video
CAMERA_SOURCE=0
